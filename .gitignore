# ========================================
# WHITELIST APPROACH - Ignorar todo por defecto
# ========================================
# Ignora todo
*
# Ignora todo en todos los subdirectorios
**/

# ========================================
# PERMITIR: Archivos y carpetas del proyecto
# ========================================

# --- Carpetas principales ---
!src/
!src/**
!public/
!public/**
!docs/
!docs/**

# --- Archivos de configuración del proyecto ---
!package.json
!tsconfig.json
!tsconfig.node.json
!vite.config.mts
!pwaOptions.ts
!index.html
!.editorconfig

# --- Documentación ---
!FORMATEO.md
!CHANGELOG.md
!implementacion.md
!plantilla.md

# --- Git ---
!.gitignore
!.gitattributes

# ========================================
# BLOQUEAR EXPLÍCITAMENTE (dentro de carpetas permitidas)
# ========================================
# Herramientas de formateo y linting (no usadas)
.prettierrc.cjs
.prettierignore
eslint.config.cjs
.eslintignore
.eslintrc.cjs
.vscode/

# Logs
*.log

# Build outputs
dist/
dist-ssr/
dist-zip/
dev-dist/

# Dependencies
node_modules/
.pnpm-store/

# Cache y temporales
*.local
.DS_Store
.venv/
__pycache__/
*.pyc

# Lock files (opcional - si quieres versionarlos, quítalos)
pnpm-lock.yaml
yarn.lock
bun.lock

# Python scripts auxiliares
*.py
!isi_gql_generator.py
*.pyc
__pycache__/
venv/
env/
ENV/
env.bak/
venv.bak/
requirements.txt

# CSV y archivos de datos
*.csv

# Editor
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# GraphQL Codegen - archivos generados
.schema-check.json
schema.json
src/app/modules/restaurante/generated/
